# Exclude all top-level hidden directories by convention
/.*/

# Exclude tarballs generated by `npm pack`
/*.tgz

__mocks__
__tests__

/babel.config.js
/android/src/androidTest/
/android/src/test/
/android/build/
/example/

# Source maps - not needed by consumers
/build/**/*.js.map
/build/**/*.d.ts.map

# TypeScript source - consumers use the compiled build/
/src/

# iOS - platform not supported
/ios/
